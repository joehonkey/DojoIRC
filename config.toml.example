# DojoIRC Configuration
# Edit this file and use Hamburger → Reload Config to apply changes.
# Full reference: https://github.com/joehonkey/DojoIRC/blob/main/docs/configuration.md

# ── Appearance ────────────────────────────────────────────────────────────────

theme     = "default"       # theme name from themes/ (no .toml extension)
font      = "IBM Plex Mono"
font_size = 13

# ── Servers ───────────────────────────────────────────────────────────────────
# Add one [[server]] block per IRC network.

[[server]]
name     = "LinuxDojo"
host     = "irc.linuxdojo.org"
port     = 6697
tls      = true
nick     = "yournick"        # ← change this to your IRC nick
channels = ["#dojoirc"]

# Optional SASL authentication (recommended if you have a registered account):
# [server.sasl]
# mechanism = "PLAIN"
# username  = "yournick"
# password  = "yourpassword"

# ── Additional servers ────────────────────────────────────────────────────────
# Copy and paste another [[server]] block for each network you want to join.

# [[server]]
# name     = "Libera"
# host     = "irc.libera.chat"
# port     = 6697
# tls      = true
# nick     = "yournick"
# channels = ["#linux"]
